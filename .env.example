# ============================================
# rn-ai-chat 环境变量配置模板
# 复制为 .env 后修改对应值
# ============================================

# ---- 数据库（Docker 内部通信，无需修改）----
DB_USER=postgres
DB_PASSWORD=YourStrongPassword123
DB_NAME=ai_chat
DB_HOST=postgres
DB_PORT=5432

# ---- AI 服务 API Keys ----
DEEPSEEK_API_KEY=sk-your-deepseek-key
MIMO_KEY=your-mimo-key
BOCHA_KEY=your-bocha-key
ZHIPU_API_KEY=your-zhipu-key

# ---- JWT 认证（生产环境务必修改为随机强密码）----
ACCESS_TOKEN_SECRET=your-random-access-token-secret-at-least-32-chars
REFRESH_TOKEN_SECRET=your-random-refresh-token-secret-at-least-32-chars

# ---- 生产域名 CORS（填写你的实际 HTTPS 域名，多个逗号分隔）----
# 示例：CORS_ORIGIN=https://example.com,https://www.example.com
CORS_ORIGIN=https://your-domain.com
